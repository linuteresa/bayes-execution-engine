# Local LLM (llama.cpp / llama-server). Nothing here talks to a cloud LLM.
LLAMA_CPP_BASE_URL=http://localhost:8080/v1
LLAMA_MODEL=local-gguf
LLAMA_CPP_API_KEY=not-needed

# Async service state
JOB_STORE=memory            # memory | redis
CHECKPOINTER=memory         # memory | redis | postgres | none
# REDIS_URL=redis://localhost:6379/0
# POSTGRES_DSN=postgresql://localhost:5432/bayes

# Observability
LOG_LEVEL=INFO
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
